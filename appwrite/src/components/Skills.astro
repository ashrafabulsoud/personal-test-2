---
const skillGroups = [
  {
    label: "Frontend Development",
    color: "bg-stone-800",
    textColor: "text-stone-100",
    accentColor: "text-honey-200",
    skills: ["HTML5", "CSS3", "JavaScript", "TypeScript", "Responsive Design", "Accessibility (a11y)"],
  },
  {
    label: "Frameworks & Tools",
    color: "bg-cream-100",
    textColor: "text-stone-800",
    accentColor: "text-honey-200",
    skills: ["Astro", "Tailwind CSS", "Git & GitHub", "VS Code", "Figma", "REST APIs"],
  },
  {
    label: "Business & Strategy",
    color: "bg-serenade-50",
    textColor: "text-stone-800",
    accentColor: "text-stone-600",
    skills: ["Requirements Gathering", "Stakeholder Management", "Sales Strategy", "Financial Analysis", "CRM Systems", "Agile"],
  },
  {
    label: "Languages",
    color: "bg-minty-100/40",
    textColor: "text-stone-800",
    accentColor: "text-stone-600",
    skills: ["Arabic (Native)", "English (Fluent)"],
  },
];

const coreStrengths = [
  {
    title: "Technical depth",
    description: "Strong web fundamentals built from the ground up — from semantic HTML to modern JavaScript patterns.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  },
  {
    title: "Business fluency",
    description: "Rare ability to speak both technical and business language — translating requirements into solutions.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  },
  {
    title: "Cross-cultural reach",
    description: "Bilingual Arabic/English and a background across Saudi Arabia and the UK — built for global teams.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>`,
  },
];
---

<section
  id="skills"
  class="relative border-b border-bone-100 px-8 py-16 sm:px-10 sm:py-20 lg:px-15 lg:py-24"
>
  <div class="bg-dots pointer-events-none absolute inset-0 opacity-20" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-6xl">
    <!-- Section header -->
    <div class="mb-12 flex flex-col gap-4">
      <div class="inline-flex w-fit items-center gap-2 rounded-full border border-bone-300 bg-cream-100 px-3 py-1">
        <span class="h-1.5 w-1.5 rounded-full bg-honey-200"></span>
        <span class="text-xs font-medium text-stone-600">Skills</span>
      </div>
      <h2 class="font-outfit text-4xl font-black text-stone-900 sm:text-5xl">
        What I bring<span class="text-honey-200"> to the table.</span>
      </h2>
    </div>

    <!-- Core strengths — bento row -->
    <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
      {
        coreStrengths.map((s) => (
          <div class="flex flex-col gap-4 rounded-2xl border border-bone-100 bg-cream-100 p-6 transition-all duration-300 hover:border-honey-200/50 hover:shadow-sm">
            <div class="text-honey-200" set:html={s.icon} />
            <div>
              <h3 class="font-semibold text-stone-900">{s.title}</h3>
              <p class="mt-1 text-sm leading-relaxed text-stone-600">{s.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Skill group cards -->
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        skillGroups.map((group) => (
          <div class={`rounded-2xl p-6 ${group.color}`}>
            <h3 class={`mb-4 text-xs font-semibold uppercase tracking-wider ${group.textColor} opacity-60`}>
              {group.label}
            </h3>
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span
                  class={`rounded-full border px-3 py-1 text-sm font-medium ${
                    group.color === "bg-stone-800"
                      ? "border-stone-700 text-stone-300"
                      : "border-bone-300 text-stone-700"
                  }`}
                >
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Currently learning -->
    <div class="mt-6 flex items-center gap-4 rounded-2xl border border-dashed border-honey-200 bg-honey-50 p-5">
      <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-honey-200/30">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-stone-700"
        >
          <path d="M12 20h9" />
          <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-semibold text-stone-800">Currently exploring</p>
        <p class="text-sm text-stone-600">
          React, Node.js, Laravel, and cloud infrastructure — always levelling up.
        </p>
      </div>
    </div>
  </div>
</section>
