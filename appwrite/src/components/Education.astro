---
---

<section
  id="education"
  class="relative border-b border-bone-100 px-8 py-16 sm:px-10 sm:py-20 lg:px-15 lg:py-24"
>
  <div class="bg-dots pointer-events-none absolute inset-0 opacity-15" aria-hidden="true"></div>
  <div class="relative mx-auto max-w-6xl">
    <div class="grid grid-cols-1 gap-12 lg:grid-cols-2 lg:gap-20">
      <!-- Left -->
      <div class="flex flex-col gap-6">
        <div class="inline-flex w-fit items-center gap-2 rounded-full border border-bone-300 bg-cream-100 px-3 py-1">
          <span class="h-1.5 w-1.5 rounded-full bg-honey-200"></span>
          <span class="text-xs font-medium text-stone-600">Education</span>
        </div>

        <h2 class="font-outfit text-4xl font-black text-stone-900 sm:text-5xl">
          The foundation<span class="text-honey-200"> I built on.</span>
        </h2>

        <p class="text-base leading-relaxed text-stone-600">
          A formal Computer Science education gave me the theoretical grounding — algorithms,
          data structures, software engineering principles — that underpins everything I build today.
        </p>

        <!-- Degree card -->
        <div class="flex gap-5 rounded-2xl bg-stone-800 p-6 sm:p-8">
          <!-- Icon -->
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-honey-200/20">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-honey-200"
            >
              <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
              <path d="M6 12v5c3 3 9 3 12 0v-5" />
            </svg>
          </div>

          <div>
            <div class="mb-1 text-xs font-medium uppercase tracking-wider text-stone-400">
              Bachelor's Degree
            </div>
            <h3 class="font-outfit text-xl font-bold text-stone-100">
              Computer Science & Information Technology
            </h3>
            <p class="mt-1 text-sm text-stone-400">
              Faculty of Computer Science and Information Technology
            </p>
            <div class="mt-3 flex items-center gap-2">
              <span class="rounded-md bg-stone-700 px-2.5 py-1 text-xs text-stone-300">
                6 October University
              </span>
              <span class="text-xs text-stone-500">Egypt</span>
            </div>
          </div>
        </div>

        <!-- Lifelong learning note -->
        <div class="flex items-start gap-3 rounded-xl border border-bone-100 bg-cream-100 p-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="mt-0.5 shrink-0 text-honey-200"
          >
            <circle cx="12" cy="12" r="10" />
            <path d="M12 16v-4" />
            <path d="M12 8h.01" />
          </svg>
          <p class="text-sm leading-relaxed text-stone-600">
            Education doesn't stop at a degree. I continuously invest in self-directed learning
            through industry resources, open-source contributions, and real-world projects.
          </p>
        </div>
      </div>

      <!-- Right — Knowledge areas -->
      <div class="flex flex-col gap-4">
        <h3 class="text-sm font-semibold uppercase tracking-wider text-stone-500">
          Core Study Areas
        </h3>
        <div class="grid grid-cols-1 gap-3">
          {
            [
              {
                area: "Algorithms & Data Structures",
                desc: "Fundamental computational thinking and problem-solving.",
                icon: "⚙️",
              },
              {
                area: "Software Engineering",
                desc: "System design, lifecycle management, and best practices.",
                icon: "🏗️",
              },
              {
                area: "Database Systems",
                desc: "Relational and non-relational data modelling, SQL fundamentals.",
                icon: "🗄️",
              },
              {
                area: "Web Technologies",
                desc: "The technical foundation of modern front-end and back-end development.",
                icon: "🌐",
              },
              {
                area: "Computer Networks",
                desc: "Protocols, security fundamentals, and network architecture.",
                icon: "🔗",
              },
              {
                area: "Object-Oriented Programming",
                desc: "Core programming paradigms that power scalable software.",
                icon: "🧱",
              },
            ].map((item) => (
              <div class="flex items-start gap-4 rounded-xl border border-bone-100 bg-cream-100 px-4 py-3.5 transition-all duration-300 hover:border-bone-300">
                <span class="mt-0.5 text-lg">{item.icon}</span>
                <div>
                  <h4 class="text-sm font-semibold text-stone-800">{item.area}</h4>
                  <p class="mt-0.5 text-xs text-stone-500">{item.desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
