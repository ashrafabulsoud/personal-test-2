---
const links = [
  { label: "About", href: "#about" },
  { label: "Experience", href: "#experience" },
  { label: "Skills", href: "#skills" },
  { label: "Education", href: "#education" },
  { label: "Contact", href: "#contact" },
];
---

<header
  class="fixed top-0 left-0 right-0 z-50 border-b border-bone-100 bg-cream-50/90 backdrop-blur-sm"
>
  <nav
    class="mx-auto flex max-w-6xl items-center justify-between px-6 py-3.5"
    aria-label="Main navigation"
  >
    <!-- Logo / Name -->
    <a
      href="/"
      class="font-outfit text-base font-bold text-stone-800 transition-colors duration-300 hover:text-honey-200"
    >
      Ashraf<span class="text-honey-200">.</span>
    </a>

    <!-- Desktop Links -->
    <ul class="hidden items-center gap-1 md:flex" role="list">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="group relative inline-grid place-items-center px-2.5 py-1.5 text-sm font-medium text-stone-600 transition-all duration-300 ease-out hover:text-stone-900 focus:outline-none focus-visible:ring focus-visible:ring-honey-200/50 will-change-transform"
            >
              {link.label}
              <span class="absolute bottom-0 left-2.5 right-2.5 h-px scale-x-0 bg-honey-200 transition-transform duration-300 group-hover:scale-x-100" />
            </a>
          </li>
        ))
      }
    </ul>

    <!-- CTA -->
    <a
      href="#contact"
      class="group inline-flex items-center gap-2 rounded-full bg-stone-800 px-4 py-2 text-sm font-medium text-stone-100 transition-all duration-300 ease-out hover:bg-stone-900 focus:outline-none focus-visible:ring focus-visible:ring-stone-800/50"
    >
      Get in touch
      <span class="transition-transform duration-300 group-hover:translate-x-0.5">→</span>
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="inline-flex items-center justify-center rounded-md p-2 text-stone-600 transition-colors duration-200 hover:bg-bone-100 hover:text-stone-900 md:hidden focus:outline-none focus-visible:ring focus-visible:ring-honey-200/50"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg
        id="icon-menu"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="4" y1="6" x2="20" y2="6" />
        <line x1="4" y1="12" x2="20" y2="12" />
        <line x1="4" y1="18" x2="20" y2="18" />
      </svg>
      <svg
        id="icon-close"
        xmlns="http://www.w3.org/2000/svg"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="hidden"
      >
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-bone-100 bg-cream-50 px-6 pb-4 pt-2 md:hidden"
  >
    <ul class="flex flex-col gap-1" role="list">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              class="mobile-link block rounded-md px-3 py-2.5 text-sm font-medium text-stone-700 transition-colors duration-200 hover:bg-bone-100 hover:text-stone-900"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  const mobileLinks = document.querySelectorAll(".mobile-link");

  function toggle() {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden");
    iconMenu?.classList.toggle("hidden");
    iconClose?.classList.toggle("hidden");
    btn?.setAttribute("aria-expanded", String(!isOpen));
  }

  btn?.addEventListener("click", toggle);
  mobileLinks.forEach((link) => link.addEventListener("click", () => {
    menu?.classList.add("hidden");
    iconMenu?.classList.remove("hidden");
    iconClose?.classList.add("hidden");
    btn?.setAttribute("aria-expanded", "false");
  }));
</script>
