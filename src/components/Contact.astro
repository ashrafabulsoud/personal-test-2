---
---

<section
  id="contact"
  class="px-8 py-16 sm:px-10 sm:py-20 lg:px-15 lg:py-24"
>
  <div class="mx-auto max-w-6xl">
    <div class="relative overflow-hidden rounded-3xl bg-stone-800 px-8 py-14 sm:px-12 sm:py-16 lg:px-16">
      <!-- Decorative background elements -->
      <div
        class="absolute -top-20 -right-20 h-64 w-64 rounded-full bg-honey-200/10 blur-3xl"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -bottom-16 -left-16 h-48 w-48 rounded-full bg-minty-100/10 blur-3xl"
        aria-hidden="true"
      ></div>
      <div class="bg-dots absolute inset-0 opacity-10" aria-hidden="true"></div>

      <div class="relative grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
        <!-- Left -->
        <div class="flex flex-col gap-6">
          <div class="inline-flex w-fit items-center gap-2 rounded-full border border-stone-700 bg-stone-700/50 px-3 py-1">
            <span class="h-1.5 w-1.5 rounded-full bg-honey-200"></span>
            <span class="text-xs font-medium text-stone-300">Get in touch</span>
          </div>

          <h2 class="font-outfit text-4xl font-black leading-tight text-stone-100 sm:text-5xl">
            Let's build something
            <span class="text-honey-200"> great together.</span>
          </h2>

          <p class="text-base leading-relaxed text-stone-400">
            Whether you're looking for a developer, exploring a collaboration, or just want
            to connect — I'd love to hear from you. I'm open to full-time roles,
            freelance projects, and interesting conversations.
          </p>

          <!-- Contact links -->
          <div class="flex flex-col gap-3">
            <a
              href="https://www.linkedin.com/in/ashrafabulsoud/"
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center gap-3 rounded-xl border border-stone-700 bg-stone-700/40 px-5 py-3.5 text-stone-300 transition-all duration-300 hover:border-honey-200/40 hover:bg-stone-700/60 hover:text-stone-100 focus:outline-none focus-visible:ring focus-visible:ring-honey-200/50"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect width="4" height="12" x="2" y="9" />
                <circle cx="4" cy="4" r="2" />
              </svg>
              <span class="text-sm font-medium">Connect on LinkedIn</span>
              <span class="ml-auto transition-transform duration-300 group-hover:translate-x-0.5">→</span>
            </a>

            <a
              href="mailto:hello@ashrafabulsoud.dev"
              class="group inline-flex items-center gap-3 rounded-xl border border-stone-700 bg-stone-700/40 px-5 py-3.5 text-stone-300 transition-all duration-300 hover:border-honey-200/40 hover:bg-stone-700/60 hover:text-stone-100 focus:outline-none focus-visible:ring focus-visible:ring-honey-200/50"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
              <span class="text-sm font-medium">hello@ashrafabulsoud.dev</span>
              <span class="ml-auto transition-transform duration-300 group-hover:translate-x-0.5">→</span>
            </a>
          </div>
        </div>

        <!-- Right — Quick facts -->
        <div class="flex flex-col justify-center gap-5">
          <p class="text-sm font-semibold uppercase tracking-wider text-stone-500">Quick facts</p>

          <div class="grid grid-cols-1 gap-3">
            {
              [
                { label: "Location", value: "London, United Kingdom", icon: "📍" },
                { label: "Current role", value: "Web Developer @ Al-Fanar Media", icon: "💼" },
                { label: "Languages", value: "Arabic (native) · English (fluent)", icon: "🌍" },
                { label: "Background", value: "CS Degree + Finance + Sales", icon: "🎓" },
                { label: "Status", value: "Open to opportunities", icon: "✅" },
              ].map((fact) => (
                <div class="flex items-center gap-3 rounded-lg border border-stone-700 bg-stone-700/30 px-4 py-3">
                  <span class="text-base">{fact.icon}</span>
                  <div class="min-w-0 flex-1">
                    <span class="text-xs text-stone-500">{fact.label}</span>
                    <p class="truncate text-sm font-medium text-stone-200">{fact.value}</p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
