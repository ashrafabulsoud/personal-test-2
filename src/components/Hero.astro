---
---

<section
  id="home"
  class="relative overflow-hidden border-b border-bone-100 pt-32 pb-20 sm:pt-40 sm:pb-24 lg:pt-48 lg:pb-32"
>
  <!-- Dot pattern background -->
  <div class="bg-dots absolute inset-0 opacity-40" aria-hidden="true"></div>

  <!-- Warm gradient overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-br from-cream-50 via-cream-50/80 to-honey-50/60"
    aria-hidden="true"
  ></div>

  <!-- Decorative orbs -->
  <div
    class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-honey-100/30 blur-3xl"
    aria-hidden="true"
  ></div>
  <div
    class="absolute -bottom-16 -left-16 h-56 w-56 rounded-full bg-minty-100/25 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto max-w-6xl px-8 sm:px-10 lg:px-15">
    <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-2">
      <!-- Left — Text -->
      <div class="flex flex-col gap-6">
        <!-- Status badge -->
        <div class="inline-flex w-fit items-center gap-2 rounded-full bg-stone-800 px-3.5 py-1.5 text-sm text-stone-100">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-honey-200 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-honey-200"></span>
          </span>
          Available for opportunities
        </div>

        <!-- Headline -->
        <h1 class="font-outfit text-5xl font-black leading-[1.05] text-stone-900 sm:text-6xl lg:text-7xl">
          Building the
          <span class="relative inline-block">
            <span class="relative z-10 text-honey-200">web</span>
            <span
              class="absolute -bottom-1 left-0 right-0 h-3 -rotate-1 rounded-sm bg-honey-100/60"
              aria-hidden="true"
            ></span>
          </span>
          <br />
          with purpose.
        </h1>

        <!-- Sub-headline -->
        <p class="max-w-md text-lg leading-relaxed text-stone-600">
          Web Developer at <span class="font-semibold text-stone-800">Al-Fanar Media</span> in London.
          I bring a rare blend of technical depth and business insight —
          built through years across banking, sales, and software development.
        </p>

        <!-- Location badge -->
        <div class="flex items-center gap-2 text-sm text-stone-500">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
            <circle cx="12" cy="10" r="3" />
          </svg>
          London, United Kingdom
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap items-center gap-3 pt-2">
          <a
            href="#experience"
            class="group inline-flex items-center gap-2.5 rounded-full bg-stone-800 px-6 py-3 font-medium text-stone-100 transition-all duration-300 ease-out hover:bg-stone-900 hover:gap-3 focus:outline-none focus-visible:ring focus-visible:ring-stone-800/50"
          >
            View my work
            <span class="transition-transform duration-300 group-hover:translate-x-0.5">→</span>
          </a>
          <a
            href="#contact"
            class="group inline-flex items-center gap-2.5 rounded-full border border-bone-300 bg-cream-100 px-6 py-3 font-medium text-stone-800 transition-all duration-300 ease-out hover:border-honey-200 hover:bg-honey-50 focus:outline-none focus-visible:ring focus-visible:ring-honey-200/50"
          >
            Say hello
            <span class="transition-transform duration-300 group-hover:translate-x-0.5">→</span>
          </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-3 pt-1">
          <span class="text-xs text-stone-400">Find me on</span>
          <div class="flex items-center gap-2">
            <a
              href="https://www.linkedin.com/in/ashrafabulsoud/"
              target="_blank"
              rel="noopener noreferrer"
              class="group rounded-md p-2 text-stone-500 transition-colors duration-200 hover:bg-bone-100 hover:text-stone-800 focus:outline-none focus-visible:ring focus-visible:ring-honey-200/50"
              aria-label="LinkedIn profile"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                <rect width="4" height="12" x="2" y="9" />
                <circle cx="4" cy="4" r="2" />
              </svg>
            </a>
            <a
              href="mailto:ashraf@example.com"
              class="group rounded-md p-2 text-stone-500 transition-colors duration-200 hover:bg-bone-100 hover:text-stone-800 focus:outline-none focus-visible:ring focus-visible:ring-honey-200/50"
              aria-label="Send email"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect width="20" height="16" x="2" y="4" rx="2" />
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Right — Avatar / Visual -->
      <div class="flex justify-center lg:justify-end">
        <div class="relative">
          <!-- Outer decorative ring — slow spin -->
          <div
            class="avatar-ring absolute -inset-3 rounded-full border-2 border-dashed border-bone-300 opacity-60"
            aria-hidden="true"
          ></div>

          <!-- Second orbit ring — counter spin, larger -->
          <div
            class="avatar-ring-counter absolute -inset-8 rounded-full border border-dashed border-bone-100 opacity-40"
            aria-hidden="true"
          ></div>

          <!-- Honey dot — floats up/down -->
          <div
            class="avatar-dot-honey absolute -top-2 -right-2 h-8 w-8 rounded-full bg-honey-200 shadow-[0_0_12px_2px_rgba(239,175,93,0.35)]"
            aria-hidden="true"
          ></div>

          <!-- Minty dot — floats opposite phase -->
          <div
            class="avatar-dot-minty absolute -bottom-3 -left-3 h-6 w-6 rounded-full bg-minty-100 shadow-[0_0_10px_2px_rgba(191,230,217,0.4)]"
            aria-hidden="true"
          ></div>

          <!-- Extra small powder dot — slow drift -->
          <div
            class="avatar-dot-powder absolute top-1/2 -right-6 h-3.5 w-3.5 rounded-full bg-powder-300 opacity-70"
            aria-hidden="true"
          ></div>

          <!-- Avatar circle — gentle breathe -->
          <div
            class="avatar-circle relative flex h-64 w-64 items-center justify-center overflow-hidden rounded-full bg-stone-800 text-cream-100 sm:h-80 sm:w-80 lg:h-72 lg:w-72 xl:h-80 xl:w-80"
          >
            <!-- Initials -->
            <span class="font-outfit text-7xl font-black select-none sm:text-8xl">AA</span>

            <!-- Subtle inner border -->
            <div
              class="absolute inset-0 rounded-full shadow-[inset_0_0_0_1px_rgba(255,255,255,0.1)]"
              aria-hidden="true"
            ></div>

            <!-- Shine sweep on load -->
            <div class="avatar-shine absolute inset-0 rounded-full" aria-hidden="true"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Stats row -->
    <div
      class="mt-16 grid grid-cols-2 gap-4 border-t border-bone-100 pt-10 sm:grid-cols-4"
    >
      {
        [
          { value: "5+", label: "Years in Tech & Business" },
          { value: "2", label: "Languages (AR + EN)" },
          { value: "3+", label: "Industries Spanned" },
          { value: "LON", label: "Based in London" },
        ].map((stat) => (
          <div class="text-center">
            <div class="font-outfit text-3xl font-black text-stone-900">{stat.value}</div>
            <div class="mt-1 text-xs text-stone-500">{stat.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* ── Outer dashed ring: slow clockwise spin ── */
  .avatar-ring {
    animation: spin-cw 18s linear infinite;
  }

  /* ── Inner counter ring: slow counter-clockwise spin ── */
  .avatar-ring-counter {
    animation: spin-ccw 28s linear infinite;
  }

  /* ── Honey dot: float up/down ── */
  .avatar-dot-honey {
    animation: float-y 3.6s ease-in-out infinite;
  }

  /* ── Minty dot: float opposite phase ── */
  .avatar-dot-minty {
    animation: float-y 4.2s ease-in-out infinite reverse;
  }

  /* ── Powder dot: slow diagonal drift ── */
  .avatar-dot-powder {
    animation: float-xy 5s ease-in-out infinite;
  }

  /* ── Avatar circle: gentle breathe (subtle scale pulse) ── */
  .avatar-circle {
    animation: breathe 6s ease-in-out infinite;
  }

  /* ── Shine sweep on load ── */
  .avatar-shine {
    background: linear-gradient(
      115deg,
      transparent 30%,
      rgba(255, 255, 255, 0.08) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
    animation: shine-sweep 1.4s ease-out 0.3s forwards;
    opacity: 0;
  }

  /* ── Keyframes ── */
  @keyframes spin-cw {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  @keyframes spin-ccw {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
  }

  @keyframes float-y {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-10px); }
  }

  @keyframes float-xy {
    0%, 100% { transform: translate(0px, 0px); }
    33%       { transform: translate(4px, -6px); }
    66%       { transform: translate(-3px, -4px); }
  }

  @keyframes breathe {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.018); }
  }

  @keyframes shine-sweep {
    0%   { opacity: 1; background-position: 200% 0; }
    100% { opacity: 0; background-position: -200% 0; }
  }

  /* Respect reduced-motion preference */
  @media (prefers-reduced-motion: reduce) {
    .avatar-ring,
    .avatar-ring-counter,
    .avatar-dot-honey,
    .avatar-dot-minty,
    .avatar-dot-powder,
    .avatar-circle,
    .avatar-shine {
      animation: none;
    }
  }
</style>
